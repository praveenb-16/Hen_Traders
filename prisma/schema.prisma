generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model KattiKoli {
  id            String        @id @default(cuid())
  date          DateTime      @default(now())
  box1          Int
  hen1          Int
  box2          Int
  hen2          Int
  box3          Int?
  hen3          Int?
  totalHens     Int
  freeHen       Int?
  rate          Float
  amount        Float
  labour        Float
  total         Float
  dailyBalance  DailyBalance  @relation(fields: [dailyBalanceId], references: [id])
  dailyBalanceId String        @unique
  createdAt     DateTime      @default(now())

  @@index([date])
}

model NallaKoli {
  id            String        @id @default(cuid())
  date          DateTime      @default(now())
  box1          Int
  hen1          Int
  box2          Int
  hen2          Int
  box3          Int?
  hen3          Int?
  totalHens     Int
  freeHen       Int?
  netWeight     Float
  waterWeight   Float
  weight        Float
  rate          Float
  amount        Float
  labour        Float
  total         Float
  dailyBalance  DailyBalance  @relation(fields: [dailyBalanceId], references: [id])
  dailyBalanceId String        @unique
  createdAt     DateTime      @default(now())

  @@index([date])
}

model BothTransaction {
  id            String        @id @default(cuid())
  date          DateTime      @default(now())

  // Katti Koli fields
  kBox1         Int
  kHen1         Int
  kBox2         Int
  kHen2         Int
  kBox3         Int?
  kHen3         Int?
  kTotalHens    Int
  kFreeHen      Int?
  kRate         Float
  kAmount       Float
  kLabour       Float
  kTotal        Float

  // Nalla Koli fields
  nBox1         Int
  nHen1         Int
  nBox2         Int
  nHen2         Int
  nBox3         Int?
  nHen3         Int?
  nTotalHens    Int
  nFreeHen      Int?
  nNetWeight    Float
  nWaterWeight  Float
  nWeight       Float
  nRate         Float
  nAmount       Float
  totalAmount   Float
  dailyBalance  DailyBalance  @relation(fields: [dailyBalanceId], references: [id])
  dailyBalanceId String        @unique
  createdAt     DateTime      @default(now())

  @@index([date])
}

model DailyBalance {
  id              String            @id @default(cuid())
  date            DateTime          @default(now())
  henType         HenType
  totalAmount     Float
  paidAmount      Float
  todayAmount     Float
  todayType       DiffType
  oldAmount       Float
  oldType         DiffType
  finalAmount     Float
  finalType       DiffType
  kattiKoli       KattiKoli?
  nallaKoli       NallaKoli?
  bothTransaction BothTransaction?
  createdAt       DateTime          @default(now())

  @@index([date])
}

enum HenType {
  KATTI_KOLI
  NALLA_KOLI
  BOTH
}

enum DiffType {
  BALANCE
  EXTRA
}
